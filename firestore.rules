rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - email: string (required, email format) - User's email
    //   - displayName: string (optional) - User's display name
    //   - role: string (required, enum: ['ADMIN', 'VENDOR', 'BUYER']) - User's role
    //   - createdAt: timestamp (optional) - Account creation timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN' ||
          (request.auth.token.email == "instantassetrecovery830@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['ADMIN', 'VENDOR', 'BUYER'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'BUYER') || 
                    (isAdmin() && isValidUser(request.resource.data));
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role) || 
                    (isAdmin() && isValidUser(request.resource.data));
      allow delete: if isAdmin();
    }

    match /vendors/{vendorId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin() || isOwner(vendorId);
    }

    match /products/{productId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/vendors/$(request.auth.uid)).data != null);
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && (resource == null || resource.data.customerUid == request.auth.uid));
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /cms/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /contacts/{contactId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /waitlist/{waitlistId} {
      allow read: if isAdmin();
      allow create: if true;
    }

    match /cart_items/{itemId} {
      allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /saved_items/{itemId} {
      allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /chat_messages/{msgId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /product_votes/{voteId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
