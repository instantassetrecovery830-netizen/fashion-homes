{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User's email" },
        "name": { "type": "string", "description": "User's display name" },
        "role": { "type": "string", "enum": ["ADMIN", "VENDOR", "BUYER"], "description": "User's role in the system" },
        "avatar": { "type": "string", "description": "User's avatar URL" },
        "joined": { "type": "string", "format": "date-time", "description": "Account creation timestamp" },
        "status": { "type": "string", "enum": ["ACTIVE", "SUSPENDED"], "description": "User's account status" },
        "spend": { "type": "string" },
        "location": { "type": "string" },
        "phone": { "type": "string" },
        "shippingAddress": { "type": "object" },
        "measurements": { "type": "object" }
      },
      "required": ["id", "email", "role", "name"]
    },
    "Vendor": {
      "title": "Vendor",
      "description": "Vendor/Designer profile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "bio": { "type": "string" },
        "avatar": { "type": "string" },
        "verificationStatus": { "type": "string", "enum": ["PENDING", "VERIFIED", "REJECTED"] },
        "subscriptionStatus": { "type": "string", "enum": ["ACTIVE", "INACTIVE"] },
        "location": { "type": "string" },
        "coverImage": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "subscriptionPlan": { "type": "string", "enum": ["Atelier", "Maison", "Couture"] },
        "website": { "type": "string" },
        "instagram": { "type": "string" },
        "twitter": { "type": "string" },
        "facebook": { "type": "string" },
        "tiktok": { "type": "string" },
        "paymentMethods": { "type": "array" },
        "kycDocuments": { "type": "object" },
        "visualTheme": { "type": "string", "enum": ["MINIMALIST", "DARK", "GOLD"] },
        "gallery": { "type": "array" },
        "videoUrl": { "type": "string" }
      },
      "required": ["id", "name", "email"]
    },
    "Product": {
      "title": "Product",
      "description": "Product listing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "designer": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "images": { "type": "array" },
        "video": { "type": "string" },
        "description": { "type": "string" },
        "rating": { "type": "number" },
        "isNewSeason": { "type": "boolean" },
        "stock": { "type": "integer" },
        "sizes": { "type": "array" },
        "isPreOrder": { "type": "boolean" },
        "releaseDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "votes": { "type": "integer" },
        "dropDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "designer", "price", "category", "image", "description", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "customerUid": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["Processing", "Shipped", "Delivered"] },
        "items": { "type": "array" }
      },
      "required": ["id", "customerName", "date", "total", "status", "items"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "date": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["ORDER", "SYSTEM", "PROMO", "ALERT"] },
        "link": { "type": "string" }
      },
      "required": ["id", "title", "message", "read", "date", "type"]
    },
    "Contact": {
      "title": "Contact",
      "description": "Contact form submission",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["NEW", "READ", "ARCHIVED"] }
      },
      "required": ["id", "name", "email", "subject", "message", "date", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles"
    },
    "/vendors/{vendorId}": {
      "schema": "Vendor",
      "description": "Vendor profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product listings"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/notifications/{notifId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "/contacts/{contactId}": {
      "schema": "Contact",
      "description": "Contact form submissions"
    },
    "/cms/{docId}": {
      "schema": "object",
      "description": "CMS content (landing, about, pricing, etc.)"
    },
    "/waitlist/{waitlistId}": {
      "schema": "object",
      "description": "Waitlist entries"
    },
    "/followers/{followerId}": {
      "schema": "object",
      "description": "Vendor followers"
    }
  }
}
